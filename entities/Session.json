{
  "name": "Session",
  "type": "object",
  "properties": {
    "specialist_name": {
      "type": "string",
      "description": "\u0627\u0633\u0645 \u0627\u0644\u0645\u062a\u062e\u0635\u0635"
    },
    "specialist_image": {
      "type": "string",
      "description": "\u0635\u0648\u0631\u0629 \u0627\u0644\u0645\u062a\u062e\u0635\u0635"
    },
    "session_type": {
      "type": "string",
      "enum": [
        "speech_therapy",
        "occupational_therapy",
        "behavioral_therapy",
        "physical_therapy",
        "psychological",
        "educational"
      ],
      "description": "\u0646\u0648\u0639 \u0627\u0644\u062c\u0644\u0633\u0629"
    },
    "session_date": {
      "type": "string",
      "format": "date-time",
      "description": "\u062a\u0627\u0631\u064a\u062e \u0648\u0648\u0642\u062a \u0627\u0644\u062c\u0644\u0633\u0629"
    },
    "status": {
      "type": "string",
      "enum": [
        "confirmed",
        "pending",
        "completed",
        "cancelled"
      ],
      "default": "pending",
      "description": "\u062d\u0627\u0644\u0629 \u0627\u0644\u062c\u0644\u0633\u0629"
    },
    "child_profile_id": {
      "type": "string",
      "description": "\u0645\u0639\u0631\u0641 \u0645\u0644\u0641 \u0627\u0644\u0637\u0641\u0644"
    },
    "notes": {
      "type": "string",
      "description": "\u0645\u0644\u0627\u062d\u0638\u0627\u062a"
    }
  },
  "required": [
    "specialist_name",
    "session_type",
    "session_date"
  ]
}