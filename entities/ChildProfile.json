{
  "name": "ChildProfile",
  "type": "object",
  "properties": {
    "child_name": {
      "type": "string",
      "description": "\u0627\u0633\u0645 \u0627\u0644\u0637\u0641\u0644"
    },
    "age": {
      "type": "number",
      "description": "\u0639\u0645\u0631 \u0627\u0644\u0637\u0641\u0644"
    },
    "gender": {
      "type": "string",
      "enum": [
        "male",
        "female"
      ],
      "description": "\u0627\u0644\u062c\u0646\u0633"
    },
    "relationship": {
      "type": "string",
      "enum": [
        "parent",
        "mother",
        "father",
        "guardian",
        "grandparent",
        "relative"
      ],
      "description": "\u0639\u0644\u0627\u0642\u0629 \u0645\u0642\u062f\u0645 \u0627\u0644\u0637\u0644\u0628 \u0628\u0627\u0644\u0637\u0641\u0644"
    },
    "special_need": {
      "type": "string",
      "enum": [
        "autism",
        "adhd",
        "downsyndrome",
        "cerebralpalsy",
        "learningdisability",
        "speechdelay",
        "sensory",
        "other"
      ],
      "description": "\u0627\u0644\u0627\u062d\u062a\u064a\u0627\u062c \u0627\u0644\u062e\u0627\u0635 \u0627\u0644\u0631\u0626\u064a\u0633\u064a"
    },
    "skill_development": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "description": "\u0645\u062c\u0627\u0644\u0627\u062a \u062a\u0637\u0648\u064a\u0631 \u0627\u0644\u0645\u0647\u0627\u0631\u0627\u062a"
    },
    "daily_challenge": {
      "type": "string",
      "description": "\u0627\u0644\u062a\u062d\u062f\u064a\u0627\u062a \u0627\u0644\u064a\u0648\u0645\u064a\u0629"
    },
    "learning_preference": {
      "type": "string",
      "enum": [
        "visual",
        "auditory",
        "kinesthetic",
        "mixed",
        "unknown"
      ],
      "description": "\u0623\u0633\u0644\u0648\u0628 \u0627\u0644\u062a\u0639\u0644\u0645 \u0627\u0644\u0645\u0641\u0636\u0644"
    },
    "current_support": {
      "type": "string",
      "description": "\u0623\u0646\u0638\u0645\u0629 \u0627\u0644\u062f\u0639\u0645 \u0627\u0644\u062d\u0627\u0644\u064a\u0629"
    },
    "suggestions": {
      "type": "string",
      "description": "\u0645\u0639\u0644\u0648\u0645\u0627\u062a \u0648\u0627\u0642\u062a\u0631\u0627\u062d\u0627\u062a \u0625\u0636\u0627\u0641\u064a\u0629"
    },
    "status": {
      "type": "string",
      "enum": [
        "draft",
        "submitted",
        "reviewed",
        "active"
      ],
      "default": "draft",
      "description": "\u062d\u0627\u0644\u0629 \u0627\u0644\u0645\u0644\u0641"
    }
  },
  "required": [
    "child_name",
    "age",
    "gender",
    "relationship",
    "special_need"
  ]
}